                      "children": [
                        {
                          "type": "text",
                          "id": "pGUMN",
                          "name": "m1Name",
                          "fill": "$color-rich-soil",
                          "content": "Nikka Ghalili",
                          "fontFamily": "Archivo Black",
                          "fontSize": 28,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "dC0TY",
                          "name": "m1Role",
                          "fill": "$color-healthy-growth",
                          "content": "Co-Founder & Worker-Owner",
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 16,
                          "fontWeight": "600"
                        },
                        {
                          "type": "rectangle",
                          "cornerRadius": 2,
                          "id": "tLptq",
                          "name": "m1Divider",
                          "fill": "$color-sage-green",
                          "width": 48,
                          "height": 3
                        },
                        {
                          "type": "text",
                          "id": "w9Ai5",
                          "name": "m1BioP1",
                          "opacity": 0.65,
                          "fill": "$color-rich-soil",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Nikka's journey as a software developer and informational technologist in New Orleans has been shaped by movement across cultures and continents. Born to a Persian/Iranian family in Baton Rouge and raised in Dalian, China, he weaves together perspectives from multiple worlds into his tech and community work.",
                          "lineHeight": 1.75,
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 16,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "YODOj",
                          "name": "m1BioP2",
                          "opacity": 0.65,
                          "fill": "$color-rich-soil",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Since starting his software development career in 2011, Nikka has built everything from mobile apps to data pipelines to AI-powered applications. After years in the corporate tech scene at companies ranging from startups to firms like LinkedIn, a growing disconnect with its values led him to step away from Silicon Valley's corporate world.",
                          "lineHeight": 1.75,
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 16,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "wZQbP",
                          "name": "m1BioP3",
                          "opacity": 0.65,
                          "fill": "$color-rich-soil",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Today, Nikka is deeply involved in New Orleans' solidarity economy, passionate about movements shifting away from extractive capitalism toward economic models rooted in mutual aid and cooperation. Through Mycelium Tech Coop, he's working to help the solidarity economy movement achieve tech sovereignty.",
                          "lineHeight": 1.75,
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 16,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "I6cPC",
                          "name": "m1Quote",
                          "width": "fill_container",
                          "gap": 16,
                          "padding": [
                            16,
                            0,
                            0,
                            0
                          ],
                          "children": [
                            {
                              "type": "rectangle",
                              "cornerRadius": 2,
                              "id": "iB6Zj",
                              "name": "m1QuoteLine",
                              "fill": "$color-healthy-growth",
                              "width": 3,
                              "height": 50
                            },
                            {
                              "type": "text",
                              "id": "knCRU",
                              "name": "m1QuoteText",
                              "opacity": 0.75,
                              "fill": "$color-rich-soil",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "What drives Nikka isn't the idea that he can single-handedly transform the world, but rather his belief in the power of interconnected movements working together.",
                              "lineHeight": 1.7,
                              "fontFamily": "IBM Plex Mono",
                              "fontSize": 16,
                              "fontWeight": "600",
                              "fontStyle": "italic"
                            }
                          ]
                        }
                      ]
