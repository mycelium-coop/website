# Public client-side values (Vite exposes VITE_* variables in the browser bundle)

# Placeholder endpoint for the contact form POST request.
# Replace with your future Cloudflare Worker endpoint when ready.
VITE_CONTACT_FORM_ENDPOINT=https://example.com/api/contact

# Cloudflare Turnstile site key (public key).
# Cloudflare test key shown here for local/dev scaffolding.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Destination address included in the form payload and footer mailto link.
VITE_CONTACT_EMAIL=hello@mycelium.coop
